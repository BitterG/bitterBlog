---
import '../styles/global.css';
import { getCollection } from 'astro:content';
import { getCategoryName } from '../utils/categories';

export interface Props {
  title?: string;
  description?: string;
}

const { title, description } = Astro.props;
const pageTitle = title ? `${title} — bitterBlog` : 'bitterBlog — 技术博客';
const pageDescription = description ?? '技术探索与思考，记录前端、后端与系统设计中的实践与感悟。';

// Build search index for NavBar
const allPosts = await getCollection('posts');
const searchIndex = JSON.stringify(allPosts.map(p => ({
  slug: p.slug,
  title: p.data.title,
  category: getCategoryName(p.data.category),
  tags: p.data.tags || [],
})));
---

<!doctype html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={pageDescription} />
  <title>{pageTitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet" />
</head>
<body>
  <slot />
  <script define:vars={{ searchIndex }}>
    window.__SEARCH_INDEX__ = JSON.parse(searchIndex);
  </script>
</body>
</html>
