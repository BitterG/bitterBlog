---
import { getCategoryName } from '../utils/categories';

export interface Post {
  slug: string;
  data: {
    title: string;
    date: string;
    category: string;
    tags?: string[];
  };
  body?: string;
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, date, category, tags = [] } = post.data;

// Generate excerpt from body (first 150 chars of plain text)
const bodyText = post.body ?? '';
const excerpt = bodyText
  .replace(/^#{1,6}\s+/gm, '')
  .replace(/\*\*|__/g, '')
  .replace(/\*|_/g, '')
  .replace(/`{1,3}[^`]*`{1,3}/g, '')
  .replace(/```[\s\S]*?```/g, '')
  .replace(/!\[.*?\]\(.*?\)/g, '')
  .replace(/\[([^\]]*)\]\(.*?\)/g, '$1')
  .replace(/>\s+/gm, '')
  .replace(/\n+/g, ' ')
  .trim()
  .slice(0, 150);

const categoryName = getCategoryName(category);
---

<article class="article-card">
  <div class="article-card-image">
    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
      <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
      <polyline points="14 2 14 8 20 8"/>
      <line x1="16" y1="13" x2="8" y2="13"/>
      <line x1="16" y1="17" x2="8" y2="17"/>
      <line x1="10" y1="9" x2="8" y2="9"/>
    </svg>
  </div>
  <div class="article-card-body">
    <div class="article-card-tags">
      <span class="article-card-tag">{categoryName}</span>
      {tags.slice(0, 3).map(tag => <span class="article-card-tag">{tag}</span>)}
    </div>
    <h3 class="article-card-title display-sm">
      <a href={`/posts/${post.slug}`}>{title}</a>
    </h3>
    <p class="article-card-excerpt body-sm">{excerpt}</p>
    <div class="article-card-meta">
      <span class="article-card-date">{date}</span>
      <span class="article-card-category">{categoryName}</span>
    </div>
  </div>
</article>
