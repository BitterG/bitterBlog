---
import { getCategoryName } from '../utils/categories';

export interface Post {
  slug: string;
  data: {
    title: string;
    date: string;
    category: string;
    tags?: string[];
  };
  body?: string;
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const { title, date, category, tags = [] } = post.data;

// Generate excerpt from body (first 150 chars of plain text)
const bodyText = post.body ?? '';
const excerpt = bodyText
  .replace(/^#{1,6}\s+/gm, '')
  .replace(/\*\*|__/g, '')
  .replace(/\*|_/g, '')
  .replace(/`{1,3}[^`]*`{1,3}/g, '')
  .replace(/```[\s\S]*?```/g, '')
  .replace(/!\[.*?\]\(.*?\)/g, '')
  .replace(/\[([^\]]*)\]\(.*?\)/g, '$1')
  .replace(/>\s+/gm, '')
  .replace(/\n+/g, ' ')
  .trim()
  .slice(0, 150);

const categoryName = getCategoryName(category);

// Extract first image from body
const firstImage = bodyText.match(/!\[[^\]]*\]\(([^)]+)\)/)?.[1] ?? null;
---

<article class="article-card">
  <div class="article-card-image">
    <img src={firstImage || `https://uapis.cn/api/v1/random/image?category=bq&type=ikun&_=${post.slug}`} alt={title} loading="lazy" />
  </div>
  <div class="article-card-body">
    <div class="article-card-tags">
      <span class="article-card-tag">{categoryName}</span>
      {tags.filter(t => t !== categoryName && t !== category).slice(0, 3).map(tag => <span class="article-card-tag">{tag}</span>)}
    </div>
    <h3 class="article-card-title display-sm">
      <a href={`/posts/${post.slug}`}>{title}</a>
    </h3>
    <p class="article-card-excerpt body-sm">{excerpt}</p>
    <div class="article-card-meta">
      <span class="article-card-date">{date}</span>
      <span class="article-card-category">{categoryName}</span>
    </div>
  </div>
</article>
