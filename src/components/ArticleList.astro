---
import ArticleCard from './ArticleCard.astro';
import type { Post } from './ArticleCard.astro';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
const totalCount = posts.length;

// Serialize posts data for client-side search
const serializedPosts = JSON.stringify(posts.map(p => {
  const bodyText = p.body ?? '';
  const excerpt = bodyText
    .replace(/^#{1,6}\s+/gm, '')
    .replace(/\*\*|__/g, '')
    .replace(/\*|_/g, '')
    .replace(/`{1,3}[^`]*`{1,3}/g, '')
    .replace(/```[\s\S]*?```/g, '')
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[([^\]]*)\]\(.*?\)/g, '$1')
    .replace(/>\s+/gm, '')
    .replace(/\n+/g, ' ')
    .trim()
    .slice(0, 150);
  return {
    slug: p.slug,
    title: p.data.title,
    date: p.data.date,
    category: p.data.category,
    tags: p.data.tags || [],
    excerpt,
  };
}));
---

<section class="articles-section">
  <div class="articles-header">
    <h2 class="display-lg">最新文章.</h2>
    <p class="body-md" style="color: var(--body)">共 <span id="articleCount">{totalCount}</span> 篇文章</p>
  </div>
  <div class="articles-grid" id="articlesGrid">
    {posts.slice(0, 6).map(post => <ArticleCard post={post} />)}
  </div>
  <div class="articles-empty" id="articlesEmpty" style="display:none;">
    <p class="body-lg" style="color: var(--mute)">没有找到匹配的文章.</p>
  </div>
  {totalCount > 6 && (
    <div class="articles-footer" id="articlesFooter">
      <button class="button-secondary" id="loadMoreBtn">加载更多</button>
    </div>
  )}
</section>

<script define:vars={{ serializedPosts }}>
  const PAGE_SIZE = 6;
  let currentPage = 1;

  interface PostData {
    slug: string;
    title: string;
    date: string;
    category: string;
    tags: string[];
    excerpt: string;
  }

  const allPosts: PostData[] = JSON.parse(serializedPosts);
  let filteredPosts = [...allPosts];

  const searchInput = document.getElementById('searchInput') as HTMLInputElement | null;
  const articlesGrid = document.getElementById('articlesGrid');
  const articlesEmpty = document.getElementById('articlesEmpty');
  const articlesFooter = document.getElementById('articlesFooter');
  const loadMoreBtn = document.getElementById('loadMoreBtn');
  const articleCount = document.getElementById('articleCount');

  function createArticleHTML(post: PostData): string {
    const tagHTML = [post.category, ...post.tags.slice(0, 3)]
      .map(t => `<span class="article-card-tag">${t}</span>`)
      .join('');
    return `
      <article class="article-card">
        <div class="article-card-image">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="16" y1="13" x2="8" y2="13"/>
            <line x1="16" y1="17" x2="8" y2="17"/>
            <line x1="10" y1="9" x2="8" y2="9"/>
          </svg>
        </div>
        <div class="article-card-body">
          <div class="article-card-tags">${tagHTML}</div>
          <h3 class="article-card-title display-sm">
            <a href="./posts/${post.slug}/">${post.title}</a>
          </h3>
          <p class="article-card-excerpt body-sm">${post.excerpt}</p>
          <div class="article-card-meta">
            <span class="article-card-date">${post.date}</span>
            <span class="article-card-category">${post.category}</span>
          </div>
        </div>
      </article>`;
  }

  function filterPosts(query: string) {
    const q = query.toLowerCase().trim();
    if (!q) {
      filteredPosts = [...allPosts];
    } else {
      filteredPosts = allPosts.filter(p =>
        p.title.toLowerCase().includes(q) ||
        p.excerpt.toLowerCase().includes(q) ||
        p.tags.some(t => t.toLowerCase().includes(q)) ||
        p.category.toLowerCase().includes(q)
      );
    }
  }

  function renderPage(reset: boolean) {
    if (reset && articlesGrid) {
      articlesGrid.innerHTML = '';
    }

    const startIdx = reset ? 0 : (currentPage - 1) * PAGE_SIZE;
    const visible = filteredPosts.slice(startIdx, startIdx + PAGE_SIZE);

    if (reset && articlesGrid) {
      visible.forEach(post => {
        articlesGrid.insertAdjacentHTML('beforeend', createArticleHTML(post));
      });
    }

    const hasMore = startIdx + PAGE_SIZE < filteredPosts.length;
    if (articlesEmpty) {
      articlesEmpty.style.display = filteredPosts.length === 0 ? 'block' : 'none';
    }
    if (articlesFooter) {
      articlesFooter.style.display = hasMore ? 'flex' : 'none';
    }
    if (articleCount) {
      articleCount.textContent = String(filteredPosts.length);
    }
  }

  searchInput?.addEventListener('input', function(this: HTMLInputElement) {
    currentPage = 1;
    filterPosts(this.value);
    renderPage(true);
  });

  loadMoreBtn?.addEventListener('click', () => {
    currentPage++;
    const startIdx = (currentPage - 1) * PAGE_SIZE;
    const newPosts = filteredPosts.slice(startIdx, startIdx + PAGE_SIZE);
    newPosts.forEach(post => {
      articlesGrid?.insertAdjacentHTML('beforeend', createArticleHTML(post));
    });
    const hasMore = startIdx + PAGE_SIZE < filteredPosts.length;
    if (articlesFooter) {
      articlesFooter.style.display = hasMore ? 'flex' : 'none';
    }
  });
</script>
