---
import ArticleCard from './ArticleCard.astro';
import type { Post } from './ArticleCard.astro';
import { getCategoryName } from '../utils/categories';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
const totalCount = posts.length;

// Serialize posts data for client-side search
const serializedPosts = JSON.stringify(posts.map(p => {
  const bodyText = p.body ?? '';
  const excerpt = bodyText
    .replace(/^#{1,6}\s+/gm, '')
    .replace(/\*\*|__/g, '')
    .replace(/\*|_/g, '')
    .replace(/`{1,3}[^`]*`{1,3}/g, '')
    .replace(/```[\s\S]*?```/g, '')
    .replace(/!\[.*?\]\(.*?\)/g, '')
    .replace(/\[([^\]]*)\]\(.*?\)/g, '$1')
    .replace(/>\s+/gm, '')
    .replace(/\n+/g, ' ')
    .trim()
    .slice(0, 150);
  const firstImage = bodyText.match(/!\[[^\]]*\]\(([^)]+)\)/)?.[1] ?? null;
  return {
    slug: p.slug,
    title: p.data.title,
    date: p.data.date,
    category: getCategoryName(p.data.category),
    categoryId: p.data.category,
    tags: p.data.tags || [],
    excerpt,
    firstImage,
  };
}));
---

<section class="articles-section">
  <div class="articles-header">
    <h2 class="display-lg">最新文章.</h2>
    <p class="body-md" style="color: var(--body)">共 <span id="articleCount">{totalCount}</span> 篇文章</p>
  </div>
  <div class="articles-grid" id="articlesGrid">
    {posts.slice(0, 6).map(post => <ArticleCard post={post} />)}
  </div>
  <div class="articles-empty" id="articlesEmpty" style="display:none;">
    <p class="body-lg" style="color: var(--mute)">没有找到匹配的文章.</p>
  </div>
  {totalCount > 6 && (
    <div class="articles-footer" id="articlesFooter">
      <button class="button-secondary" id="loadMoreBtn">加载更多</button>
    </div>
  )}
</section>

<script define:vars={{ serializedPosts }}>
  var PAGE_SIZE = 6;
  var currentPage = 1;

  var allPosts = JSON.parse(serializedPosts);

  var filteredPosts = allPosts.slice();

  // DOM refs
  var searchInput = document.getElementById('searchInput');
  var articlesGrid = document.getElementById('articlesGrid');
  var articlesEmpty = document.getElementById('articlesEmpty');
  var articlesFooter = document.getElementById('articlesFooter');
  var loadMoreBtn = document.getElementById('loadMoreBtn');
  var articleCount = document.getElementById('articleCount');

  function createArticleHTML(post) {
    var dedupedTags = post.tags.filter(function(t) { return t !== post.category; }).slice(0, 3);
    var tagHTML = [post.category].concat(dedupedTags)
      .map(function(t) { return '<span class="article-card-tag">' + t + '</span>'; })
      .join('');
    var imgSrc = post.firstImage || 'https://uapis.cn/api/v1/random/image?category=bq&type=ikun&_=' + post.slug;
    var imageHTML = '<div class="article-card-image"><img src="' + imgSrc + '" alt="' + post.title + '" loading="lazy" /></div>';
    return '<article class="article-card">' + imageHTML +
      '<div class="article-card-body">' +
        '<div class="article-card-tags">' + tagHTML + '</div>' +
        '<h3 class="article-card-title display-sm"><a href="./posts/' + post.slug + '/">' + post.title + '</a></h3>' +
        '<p class="article-card-excerpt body-sm">' + post.excerpt + '</p>' +
        '<div class="article-card-meta">' +
          '<span class="article-card-date">' + post.date + '</span>' +
          '<span class="article-card-category">' + post.category + '</span>' +
        '</div>' +
      '</div>' +
    '</article>';
  }

  function filterPosts(query) {
    var q = query.toLowerCase().trim();
    if (!q) {
      filteredPosts = allPosts.slice();
    } else {
      filteredPosts = allPosts.filter(function(p) {
        return p.title.toLowerCase().indexOf(q) !== -1 ||
          p.excerpt.toLowerCase().indexOf(q) !== -1 ||
          p.tags.some(function(t) { return t.toLowerCase().indexOf(q) !== -1; }) ||
          p.category.toLowerCase().indexOf(q) !== -1;
      });
    }
  }

  function renderPage(reset) {
    if (reset && articlesGrid) {
      articlesGrid.innerHTML = '';
    }

    var startIdx = reset ? 0 : (currentPage - 1) * PAGE_SIZE;
    var visible = filteredPosts.slice(startIdx, startIdx + PAGE_SIZE);

    if (reset && articlesGrid) {
      visible.forEach(function(post) {
        articlesGrid.insertAdjacentHTML('beforeend', createArticleHTML(post));
      });
    }

    var hasMore = startIdx + PAGE_SIZE < filteredPosts.length;
    if (articlesEmpty) {
      articlesEmpty.style.display = filteredPosts.length === 0 ? 'block' : 'none';
    }
    if (articlesFooter) {
      articlesFooter.style.display = hasMore ? 'flex' : 'none';
    }
    if (articleCount) {
      articleCount.textContent = String(filteredPosts.length);
    }
  }

  if (searchInput) {
    searchInput.addEventListener('input', function() {
      currentPage = 1;
      filterPosts(this.value);
      renderPage(true);
    });
  }

  if (loadMoreBtn) {
    loadMoreBtn.addEventListener('click', function() {
      currentPage++;
      var startIdx = (currentPage - 1) * PAGE_SIZE;
      var newPosts = filteredPosts.slice(startIdx, startIdx + PAGE_SIZE);
      newPosts.forEach(function(post) {
        if (articlesGrid) {
          articlesGrid.insertAdjacentHTML('beforeend', createArticleHTML(post));
        }
      });
      var hasMore = startIdx + PAGE_SIZE < filteredPosts.length;
      if (articlesFooter) {
        articlesFooter.style.display = hasMore ? 'flex' : 'none';
      }
    });
  }

  // Init: apply category filter from URL param
  var urlParams = new URLSearchParams(window.location.search);
  var catFilter = urlParams.get('category');
  if (catFilter) {
    filteredPosts = allPosts.filter(function(p) { return p.categoryId === catFilter; });
    renderPage(true);
    if (filteredPosts.length === 0 && articlesEmpty) {
      articlesEmpty.innerHTML = '<p class="body-lg" style="color:var(--mute)">该分类下暂无文章.</p>';
      articlesEmpty.style.display = 'block';
    }
  }
</script>
