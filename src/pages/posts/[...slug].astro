---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { getCategoryName } from '../../utils/categories';
import '../../styles/post.css';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, date, category, tags = [] } = post.data;
const categoryName = getCategoryName(category);
const { Content } = await post.render();
---

<BaseLayout title={title}>
  <NavBar />
  <article class="post-page">
    <header class="post-header">
      <h1 class="post-title display-lg">{title}</h1>
      <div class="post-meta">
        <span class="post-date">{date}</span>
        <span class="post-category">{categoryName}</span>
        {tags.slice(0, 5).map(tag => <span class="post-category">{tag}</span>)}
      </div>
    </header>
    <hr class="post-divider" />
    <div class="post-content">
      <Content />
    </div>
    <div class="post-back">
      <a href="/" class="button-secondary">← 返回首页</a>
    </div>
  </article>
  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll('.post-content pre').forEach(function(pre) {
    // 复制按钮
    var btn = document.createElement('button');
    btn.className = 'copy-btn';
    btn.textContent = '复制';
    btn.addEventListener('click', function() {
      var code = pre.querySelector('code');
      var text = code ? code.textContent : pre.textContent;
      navigator.clipboard.writeText(text).then(function() {
        btn.textContent = '已复制';
        btn.classList.add('copied');
        setTimeout(function() {
          btn.textContent = '复制';
          btn.classList.remove('copied');
        }, 1500);
      });
    });
    pre.style.position = 'relative';
    pre.appendChild(btn);

    // 长代码块折叠（超过 30 行默认折叠）
    var code = pre.querySelector('code');
    var content = code ? code.textContent : pre.textContent;
    var lines = content.split('\n').length;
    if (lines > 30) {
      var wrapper = document.createElement('div');
      wrapper.className = 'code-collapse';
      wrapper.style.position = 'relative';
      pre.parentNode.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);

      // 折叠状态
      pre.style.maxHeight = '480px';
      pre.style.overflow = 'hidden';
      pre.style.transition = 'max-height 0.4s ease';

      var toggle = document.createElement('button');
      toggle.className = 'code-toggle';
      toggle.textContent = '展开 (' + lines + ' 行)';
      toggle.addEventListener('click', function() {
        if (pre.style.maxHeight === '480px') {
          pre.style.maxHeight = 'none';
          wrapper.classList.add('expanded');
          toggle.textContent = '折叠';
          toggle.classList.add('expanded');
        } else {
          pre.style.maxHeight = '480px';
          wrapper.classList.remove('expanded');
          toggle.textContent = '展开 (' + lines + ' 行)';
          toggle.classList.remove('expanded');
        }
      });
      wrapper.appendChild(toggle);
    }
  });
</script>
